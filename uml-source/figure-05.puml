@startuml
!pragma teoz true
left to right direction
skinparam shadowing false
skinparam DefaultFontName "Microsoft YaHei"
skinparam DefaultFontSize 13
title 图8  注册用户购票用例图

actor 注册用户 as User

rectangle "购票子系统" {
  usecase "登录账号" as UC1
  usecase "查看场次" as UC2
  usecase "可视化选座" as UC3
  usecase "区域购票(ZONED/MIXED)" as UC4
  usecase "确认/创建订单" as UC5
  usecase "模拟支付" as UC6
  usecase "取消订单" as UC7
  usecase "自助退票" as UC8
  usecase "我的订单" as UC9
  usecase "查看电子票" as UC10
  usecase "发起拼座邀请" as UC11
  usecase "加入/结算拼座" as UC12
  usecase "舞台视角 3D 预览" as UC13
  usecase "个性化推荐" as UC14
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC5
User --> UC6
User --> UC9
User --> UC11
User --> UC12
User --> UC13
User --> UC14

UC3 ..> UC5 : <<include>>
UC4 ..> UC5 : <<include>>
UC5 ..> UC6 : <<include>>
UC6 ..> UC10 : <<include>>
UC3 ..> UC13 : <<extend>>
UC3 ..> UC11 : <<extend>>
UC11 ..> UC12 : <<include>>
UC9 ..> UC7 : <<extend>>
UC9 ..> UC8 : <<extend>>
@enduml
