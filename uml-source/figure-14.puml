@startuml
!pragma teoz true
skinparam shadowing false
skinparam DefaultFontName "Microsoft YaHei"
skinparam DefaultFontSize 13
title 图12  用户注册登录顺序图

actor "注册用户" as User
participant "Vue 前端页面" as FE
participant "AuthController" as AC
participant "AuthService" as AS
database "MySQL\n(sys_user)" as DB
participant "Sa-Token 服务" as Token

User -> FE : 输入账号 / 密码
FE -> AC : POST /api/auth/login
AC -> AS : login(loginDTO)
AS -> DB : SELECT sys_user WHERE username=?
DB --> AS : userEntity
AS -> AS : BCrypt 校验密码
AS -> Token : StpUtil.login(userId)
Token --> AS : tokenInfo
AS --> AC : LoginVO(token, userInfo, roles)
AC --> FE : 200 OK + token
FE -> FE : 写入 localStorage / pinia
FE --> User : 跳转主页
@enduml
