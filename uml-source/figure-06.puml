actor 票务管理员 as Admin

rectangle "票务后台子系统" {
  usecase "演出分类管理" as UC1
  usecase "剧目信息管理" as UC2
  usecase "演出厅管理" as UC3
  usecase "座位布局管理" as UC4
  usecase "场次排期管理" as UC5
  usecase "场次座位票池管理" as UC6
  usecase "订单查询与管理" as UC7
  usecase "公告管理" as UC8
  usecase "查看数据看板" as UC9
  usecase "查看销售统计" as UC10
  usecase "批量复制排期" as UC11
  usecase "退改申请审核" as UC12
  usecase "导出票房报表" as UC13
  usecase "优惠策略管理" as UC14
  usecase "运营提醒处理" as UC15
  usecase "AI 运营助手" as UC16
}

Admin --> UC1
Admin --> UC2
Admin --> UC3
Admin --> UC4
Admin --> UC5
Admin --> UC6
Admin --> UC7
Admin --> UC8
Admin --> UC9
Admin --> UC10
Admin --> UC11
Admin --> UC12
Admin --> UC13
Admin --> UC14
Admin --> UC15
Admin --> UC16

UC5 ..> UC6 : <<include>>
UC5 ..> UC11 : <<extend>>
UC2 ..> UC1 : <<include>>
UC3 ..> UC4 : <<include>>
UC9 ..> UC10 : <<extend>>
