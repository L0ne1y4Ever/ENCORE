@startuml
!pragma teoz true
skinparam shadowing false
skinparam DefaultFontName "Microsoft YaHei"
skinparam DefaultFontSize 12
title 图27  数据看板架构与数据流图

package "管理端前端 (Vue 3)" {
  component [Dashboard.vue\n暗色底 + 金色高亮 #C8955A] as DV
  component [ECharts 5.x\n透明底，金色数据系列] as EC
  component [WebSocket 客户端\n订阅 /topic/admin/dashboard] as WSC
}

package "图表与卡片(真实)" {
  component [KPI 数字卡\n营收 / 订单 / 售票 / 检票] as KPI
  component [Line + Bar 双轴\n近 7 日票房与销量趋势] as LN
  component [横向 Bar\nTop5 热门演出] as BR
  component [检票汇总卡\n已检 / 待检] as CK
}

package "后端 (Spring Boot)" {
  component [AdminController\nGET /api/admin/dashboard] as AC
  component [AdminService\n应用层内存聚合] as AS
  component [DashboardRefreshPublisher\n/topic/admin/dashboard] as DRP
}

database "MySQL\nticket_order / ticket_item\nshow / show_schedule" as DB

DV --> EC
EC --> KPI
EC --> LN
EC --> BR
EC --> CK
DV --> AC : GET /api/admin/dashboard
AC --> AS : dashboard()
AS --> DB : selectList(订单/票据/演出/场次)
DB --> AS : 实体集合
AS --> AS : stream / groupingBy 聚合
AS --> AC : DashboardResponse
AC --> DV : JSON

DRP ->> WSC : DashboardRefreshEvent\n(支付/检票事件触发)
WSC --> DV : 收到信号后重新拉取并局部刷新

note bottom of DV
  实测仅折线 + 柱状(无 Sankey / 饼图 / 热力图)；
  聚合在应用层内存完成，未引入 Redis 看板缓存；
  刷新为"事件信号 + 主动重拉"，非整页推送。
end note
@enduml
