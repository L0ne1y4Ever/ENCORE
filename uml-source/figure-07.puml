@startuml
!pragma teoz true
left to right direction
skinparam shadowing false
skinparam DefaultFontName "Microsoft YaHei"
skinparam DefaultFontSize 13
title 图10  检票员检票核销用例图

actor 检票员 as Checker

rectangle "检票核销子系统" {
  usecase "登录检票端" as UC1
  usecase "查看可检票场次" as UC2
  usecase "扫描或输入票号" as UC3
  usecase "查询票据信息" as UC4
  usecase "核验票据状态" as UC5
  usecase "核销入场" as UC6
  usecase "处理重复检票异常" as UC7
  usecase "处理作废/退票异常" as UC8
  usecase "处理非当前场次异常" as UC9
  usecase "处理未支付订单异常" as UC10
  usecase "弱网离线检票缓存" as UC11
  usecase "恢复网络后同步" as UC12
}

Checker --> UC1
Checker --> UC2
Checker --> UC3
Checker --> UC6
Checker --> UC7
Checker --> UC8
Checker --> UC9
Checker --> UC10
Checker --> UC11

UC3 ..> UC4 : <<include>>
UC4 ..> UC5 : <<include>>
UC5 ..> UC6 : <<include>>
UC5 ..> UC7 : <<extend>>
UC5 ..> UC8 : <<extend>>
UC5 ..> UC9 : <<extend>>
UC5 ..> UC10 : <<extend>>
UC6 ..> UC11 : <<extend>>
UC11 ..> UC12 : <<include>>
@enduml
