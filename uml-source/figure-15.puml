@startuml
!pragma teoz true
skinparam shadowing false
skinparam DefaultFontName "Microsoft YaHei"
skinparam DefaultFontSize 13
title 图14  可视化选座顺序图

actor "注册用户" as User
participant "用户端 (Vue 3)\nSeatMap + STOMP" as FE
participant "SeatController\n/api/schedules/{id}" as Ctrl
participant "SeatService" as Svc
database "Redis\n座位锁" as Redis
database "MySQL\nschedule_seat" as DB
participant "SeatStatusPublisher\n/topic/schedules/{id}/seats" as WS

User -> FE : 进入场次选座页
FE -> Ctrl : GET /api/schedules/{id}/seats
Ctrl -> Svc : listSeats(scheduleId)
Svc -> DB : SELECT * FROM schedule_seat\nORDER BY row_no, col_no
DB --> Svc : 座位行列 + 状态
Svc -> Redis : EXISTS encore:seat-lock:{id}:{seat}?
Redis --> Svc : 命中则覆盖为 LOCKED
Svc --> Ctrl : List<SeatResponse>\n(AVAILABLE/LOCKED/SOLD/DISABLED)
Ctrl --> FE : 200 OK + seats
FE -> WS : SUBSCRIBE /topic/schedules/{id}/seats
FE --> User : 渲染座位图(实时刷新)

== 点选 1-6 个座位并锁定 ==
User -> FE : 勾选 AVAILABLE 座位
FE -> Ctrl : POST /api/schedules/{id}/seats/lock\n{ seatIds }
Ctrl -> Svc : lockSeats(scheduleId, seatIds)
Svc -> Svc : ensureOnSaleSchedule\nnormalize(1-6) + findSeats
alt 全部 AVAILABLE 且未被他人锁定
  Svc -> Redis : SETNX encore:seat-lock:{id}:{seat}\n= userId, TTL=15min
  Redis --> Svc : 获取成功
  Svc -> WS : publishSeatStatus(LOCKED, seatIds)
  WS ->> FE : {reason:LOCKED, seats:[...]}
  Svc --> Ctrl : true
  Ctrl --> FE : 200 OK -> 进入下单
else 已被锁定 / 已售出
  Svc -> Redis : 回滚本次已获取的 key
  Svc --> Ctrl : 409 座位已被锁定，请重新选择
  Ctrl --> FE : 409 Conflict
  FE --> User : 提示重新选择
end

note over Redis, WS
  锁只存在于 Redis(不写库, LOCKED 为运行时叠加);
  @Scheduled(5s) cleanupExpiredSeatLocks 兜底,
  过期后广播 LOCK_EXPIRED -> AVAILABLE。
end note
@enduml
